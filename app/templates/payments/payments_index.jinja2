{% extends 'dashboard.jinja2' %}

{% block module %}

<h1>Pagos</h1>

<a class="btn btn-primary mb-3"
   hx-get=" {{ url_for('payments.add_form')}} "
   hx-push-url="true"
   hx-replace-url="true"
   hx-target="#module">
    <i class="bi bi-plus-circle"></i>
    Cobrar
</a>

<div class="container-fluid">
    <div class="table-responsive my-4">
        <table class="table text-center" id="mainTable">
            <thead>
                <tr>
                    <th>Acciones</th>
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Alumno</th>
                </tr>
            </thead>
            <tbody>
                {% for payment in payments %}

                <tr>
                    <td data-label="Actions">
                        <a href=""
                           class="btn btn-warning mb-3"
                           tabindex="-1"
                           role="button"
                           aria-disabled="true">Editar</a>
                        <form action=""
                              method="post">
                            <button type="submit"
                                    class="btn btn-danger">
                                Eliminar
                            </button>
                        </form>
                    </td>
                    <td data-label="Fecha">
                        {{ payment.date }}
                    </td>
                    <td data-label="Total">
                        {{ payment.total | money }}
                    </td>
                    <td data-label="Alumno">
                        {{ payment.student.user.person.name}}
                    </td>
                </tr>

                {% endfor %}
            </tbody>
        </table>
    </div>
</div>


    
{% endblock module %}

{% block scripts %}
{{ super() }}
<script src="{{ url_for('static', filename='js/dataTable.js') }}"></script>

{% endblock scripts %}